<ExplicitRule>#temp_G62_STOP_NUMBER = var_STOP_NUMBER;

if #0432:2 = "10" | 
   #0432:2 = "11" |
   #0432:2 = "69" |
   #0432:2 = "79" |
   #0432:2 = "77" then
   begin
     $204.#temp_EARLYPICKUPDATE = #0373:2;
     $204.#temp_EARLYPICKUPTIME = #0337:2;
     $204.#temp_LATEPICKUPDATE  = #0373:2;
     $204.#temp_LATEPICKUPTIME  = #0337:2;
   end
else
   if #0432:2 = "37" |
      #0432:2 = "EP" then
      begin
        $204.#temp_EARLYPICKUPDATE = #0373:2;
        $204.#temp_EARLYPICKUPTIME = #0337:2;
      end
   else
      if #0432:2 = "38" |
	 #0432:2 = "LP" then
         begin
           $204.#temp_LATEPICKUPDATE = #0373:2;
           $204.#temp_LATEPICKUPTIME = #0337:2;
         end
      else
         if #0432:2 = "02" |
            #0432:2 = "68" |
	    #0432:2 = "70" |
            #0432:2 = "78" |

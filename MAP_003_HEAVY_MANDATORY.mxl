<ExplicitRule>string[8] var_DATE;
string[8] var_TIME;

if var_SHOW_TIMEOUT = "YES" then
   begin
     #temp_OFFERWDRDATE   = #0373;
     #temp_OFFERWDRTIME   = #0337;
     #temp_DATE_QUALIFIER = #0432;
     #temp_DATE           = #0373;
     #temp_TIME_QUALIFIER = #0176;
     #temp_TIME           = #0337;
   end
else
   begin
     strdate(#0373,"%Y%m%d",var_DATE);
     strdate(#0337,"%H%M",var_TIME);
     #temp_REMARKS1:2 = "MUST RESPOND BY " + var_DATE + " " + var_TIME;
   end</ExplicitRule>

<Field>
<ID>1221</ID>
<Name>0128</Name>
<Description>REFERENCE IDENTIFICATION QUALIFIER..........NOTIFY, COMMENTS, L11</Description>
<Active>1</Active>
<ChildCount>0</ChildCount>
<Note></Note>
<Mandatory>no</Mandatory>
<NotUsed>no</NotUsed>
<FieldNumber>0</FieldNumber>
<StoreGroup>65535</StoreGroup>
<StoreField>65535</StoreField>
<BusinessName></BusinessName>
<StoreLimit>
<MaxLen>3</MaxLen>
<MinLen>2</MinLen>
<Signed>no</Signed>
<DataType>string</DataType>
<ImpliedDecimalPos>0</ImpliedDecimalPos>
<ImplicitDecimal>no</ImplicitDecimal>
<AllowSignedDecimal>0</AllowSignedDecimal>
<Format>X</Format>
<BinaryOutput>0</BinaryOutput>
<BinaryWidth>0</BinaryWidth>
</StoreLimit>
<ExplicitRule>#temp_L11_HEADER_STOP_NUMBER         = 1;
#temp_L11_HEADER_REFERENCE_QUALIFIER = #0128;

if #0128 = "SI" then
   begin
     save_L11_SI = #0127;
   end

if #0128 = "VD" then
  begin
    var_T_NBR = #0127;
  end

if #0128 = "TH" then
  begin
    var_COMPANY = #0127;
  end

///SAVE SCAC AS REFERENCENUMBERD3

$temp_S5_Group[1].#temp_RFSTOPNBR = 1; 
$temp_S5_Group[1].#temp_REFQUAL   = "DP";
$temp_S5_Group[1].#temp_REFNBR    = $204.#0140;


/////////////////////////////////**********   Before adding notify, CHR must provide T# and Customer Name - whether it be CH ROBINSON or JOE BLOW CUSTOMER     ************//////////////////
///////////////////////////////////////////  If L11*TH = CH ROBINSON then look at code list "CHRNTF CH ROBINSON BROKERAGE" - uses T# to notify AR              //////////////////////////////
///////////////////////////////////////////  If L11*TH not equal to CH ROBINSON then look at code list "CHRNTF" - uses customer name to notify AR              //////////////////////////////
///////////////////////////////////////////  If notify is based on customer name and scac - see logic below                                                    //////////////////////////////
///////////////////////////////////////////  If notify is based on customer name, scac and state, See N402 in S5 loop                                          //////////////////////////////
///////////////////////////////////////////  If no notify is set up when a 204 is received, then we will get a Sterling error message                          //////////////////////////////
 
if len($204.#temp_NOTIFYAREA) = 0 then
  begin
    if #0128 = "TH" then
      begin
        var_SHOW_TIMEOUT = "NO ";
        select RECEIVERCODE into var_SHOW_TIMEOUT
        from CODELIST 
        where NAME = "CHR_SHOW_TIMEOUT"
        and SENDERCODE = #0127;

        if #0127 = "CH ROBINSON" then
          begin
            select RECEIVERCODE into $204.#temp_NOTIFYAREA
            from CODELIST 
            where NAME = "CHRNTF CH ROBINSON BROKERAGE"
            and SENDERCODE = var_T_NBR;
                 
            select TEXT1 into $204.#temp_TRADINGPARTNER
            from CODELIST 
            where NAME = "CHRNTF CH ROBINSON BROKERAGE"
            and SENDERCODE = var_T_NBR;
	    if len($204.#temp_TRADINGPARTNER)= 0 then 
	      begin 
		$204.#temp_TRADINGPARTNER = "CHROBIN";
              end
           end
        else
          begin
            select RECEIVERCODE into $204.#temp_NOTIFYAREA
            from CODELIST 
            where NAME = "CHRNTF"
            and SENDERCODE = #0127;
	    select TEXT1 into $204.#temp_TRADINGPARTNER
            from CODELIST 
            where NAME = "CHRNTF"
            and SENDERCODE = #0127;
          end
                           
/////////////////////////////////////////       Notify based on Customer Name and SCAC      ////////////////////////////////////

if $204.#temp_TRADINGPARTNER = "CHRBBCTMC"  &amp;    //*********************** Boston Beer
   $204.#temp_SCAC           = "HJBB"       then
   begin
     $204.#temp_TRADINGPARTNER = "CHRBBCTMCB";
   end

if $204.#temp_TRADINGPARTNER = "CHRBBCTMC"  &amp;    
   $204.#temp_SCAC           = "HJBM"       then
   begin
     $204.#temp_TRADINGPARTNER = "CHRBBHJBM";
   $204.#temp_NOTIFYAREA = "TWR";
  end

if $204.#temp_TRADINGPARTNER = "CHROCEANSP" &amp;    //*********************** Ocean Spray 
   $204.#temp_SCAC           = "HJCS"  then
     begin     
       $204.#temp_TRADINGPARTNER = "CHROCNDCS";
    end

if $204.#temp_TRADINGPARTNER = "CHRFARMER" &amp;     //*********************** Farmer Brothers
   $204.#temp_SCAC           = "HJBT"  then
     begin     
       $204.#temp_TRADINGPARTNER = "CHRFARMDCS";
    end

if $204.#temp_TRADINGPARTNER = "CHRFARMER" &amp;
   $204.#temp_SCAC           = "HBJI"  then
   begin
     $204.#temp_TRADINGPARTNER = "CHRFARMJBI";
  end

if $204.#temp_TRADINGPARTNER = "CHRBDHJBT"  &amp;    //*********************** Stanley Black and Decker
   $204.#temp_SCAC           = "HJBI"       then
   begin
     $204.#temp_TRADINGPARTNER = "CHRBDHJBI";
   end

if $204.#temp_TRADINGPARTNER = "CHRBNMO"  &amp;    //*********************** Benjamin Moore
   $204.#temp_SCAC           = "HJBI"     then
   begin
     $204.#temp_TRADINGPARTNER = "CHRBNMOJBI";
   end

if $204.#temp_TRADINGPARTNER = "CHRPHARM"  &amp;    //*********************** Pharmavite
   $204.#temp_SCAC           = "HJBI"     then
   begin
     $204.#temp_TRADINGPARTNER = "CHRPHARMI";
   end


if #0127 = "BBC TMC" then
   begin
     cL11 = cL11 + 1;
     $temp_HEADER_L11_REF_NBR[cL11].#temp_HEADER_L11_REF_NBR_FIELD = save_L11_SI;
     $temp_HEADER_L11_REF_NBR[cL11].#temp_L11_HEADER_REF_QUAL      = "BN";
     $temp_HEADER_L11_REF_NBR[cL11].#temp_L11_HEADER_STOP_NUMBER:2 = 1;

    if var_T_NBR = "T2634212" then 
       begin
         cL11 = cL11 + 1;
         $temp_HEADER_L11_REF_NBR[cL11].#temp_HEADER_L11_REF_NBR_FIELD = save_L11_SI;
         $temp_HEADER_L11_REF_NBR[cL11].#temp_L11_HEADER_REF_QUAL      = "PO";
         $temp_HEADER_L11_REF_NBR[cL11].#temp_L11_HEADER_STOP_NUMBER:2 = 1;
       end
 
    if $204.#0140 = "HJBT" |
       $204.#0140 = "HJBI" |
       $204.#0140 = "HJBR" |
       $204.#0140 = "HJIR" |
       $204.#0140 = "QPMT" then
       begin
         $204.#temp_NOTIFYAREA = "NB3";
       end
    else
    if $204.#0140 = "HJBB" then
       begin
         $204.#temp_NOTIFYAREA = "TWR";
       end
    if $204.#0140 = "HJIR" then
       begin
         $204.#temp_TRADINGPARTNER = "CHRBBCTMCT";
       end
   end
else
if #0127 = "TMC CARLSTAR" &amp;           //*********************** Carlstar
   $204.#0140 = "JBHA"   then
   begin
     $204.#temp_TRADINGPARTNER = "CHRCARLB";
     $204.#temp_NOTIFYAREA     = "RT!";
   end
else


if  #0127 = "JCI-PS HAZMAT" &amp;   //*********************** CLARIOS
   ($204.#0140 = "HMKD"     |  
    $204.#0140 = "HJBI")    then
    begin
       $204.#temp_TRADINGPARTNER = "CHRCLARIOS";
    end
else
  
if #0127 = "JCI-PS HAZMAT" &amp;
   $204.#0140 = "HJBM"     then
   begin
      $204.#temp_TRADINGPARTNER = "CHRCLAMPDD";
   end 
else

if  #0127 = "JCI-PS GMSPO" &amp;   
   ($204.#0140 = "HMKD"     |  
    $204.#0140 = "HJBI")    then
    begin
       $204.#temp_TRADINGPARTNER = "CHRCLARIOS";
    end 
else
  
if #0127 = "JCI-PS GMSPO" &amp;
   $204.#0140 = "HJBM"     then
   begin
      $204.#temp_TRADINGPARTNER = "CHRCLAMPDD";
   end 
else

if  #0127 = "JOHNSON CONTROLS" &amp;   
   ($204.#0140 = "HMKD"     |  
    $204.#0140 = "HJBI")    then
    begin
       $204.#temp_TRADINGPARTNER = "CHRCLARIOS";
    end 
else
  
if #0127 = "JOHNSON CONTROLS" &amp;
   $204.#0140 = "HJBM"     then
   begin
      $204.#temp_TRADINGPARTNER = "CHRCLAMPDD";
   end 

else

if #0127 = "JOHNSON CONTROLS" &amp;
   $204.#0140 = "HJLM"     then
   begin
      $204.#temp_TRADINGPARTNER = "JHNCHCBLMN";
   end 

else

if #0127 = "TMC HUNTER DOUGLAS INBOUND" &amp;   //*********************** Hunter Douglas
   $204.#0140 = "HJBB" then 
   begin 
   $204.#temp_TRADINGPARTNER = "CHRHUNTDG";
   end

else
if #0127 = "LIPPERT TMC" &amp;   //*********************** Lippert
   $204.#0140 = "HJBT" then 
   begin 
   $204.#temp_TRADINGPARTNER = "CHRLIPPT";
   end


if #0127 = "TMC MAUSER" &amp;          //*********************** Mauser
   $204.#0140 = "HJCS"   then
    begin
      $204.#temp_TRADINGPARTNER = "CHRMSRDCS";
      $204.#temp_NOTIFYAREA     = "BTA";
    end 
if #0127 = "TMC MAUSER" &amp;  
   $204.#0140 = "HJBI" then
   begin
     $204.#temp_NOTIFYAREA     = "3C1";  
   end
if #0127 = "TMC MAUSER" &amp; 
  $204.#0140 = "HJBM"   then
    begin
      $204.#temp_TRADINGPARTNER = "CHRMSRBM";
      $204.#temp_NOTIFYAREA     = "ABW";
    end 
else
if #0127 = "TMC STARBUCKS"    |  //*********************** Starbucks
   #0127 = "SA-TMC STARBUCKS" then
   begin
     if $204.#0140 = "HJBT" |
        $204.#0140 = "HJBI" |
        $204.#0140 = "QPMT" then
        begin
          $204.#temp_NOTIFYAREA = "2DB";
        end
     else
     if $204.#0140 = "HJBB" then
        begin
          $204.#temp_TRADINGPARTNER = "CHRSTARBB";
          $204.#temp_NOTIFYAREA     = "6B7";
        end
     else
        begin
          $204.#temp_NOTIFYAREA = "PG5";
        end
   end
else
if $204.#temp_TRADINGPARTNER = "CHRORGAIN" &amp;   //**************** ORGAIN
   save_L11_SI &gt; "" then
   begin
     cL11 = cL11 + 1;
     $temp_HEADER_L11_REF_NBR[cL11].#temp_HEADER_L11_REF_NBR_FIELD = save_L11_SI;
     $temp_HEADER_L11_REF_NBR[cL11].#temp_L11_HEADER_REF_QUAL      = "BN";
     $temp_HEADER_L11_REF_NBR[cL11].#temp_L11_HEADER_STOP_NUMBER:2 = 1;
   end
else
if #0127 = "OCEAN SPRAY" then  //*********************** Ocean Spray
   begin
     if $204.#0140 = "HJBI" then
        begin
          $204.#temp_NOTIFYAREA = "9CH";
        end
     else
     if $204.#0140 = "HJBT" then
        begin 
          $204.#temp_NOTIFYAREA = "SP1";
        end
     else
     if $204.#0140 = "HJCS" then
        begin 
          $204.#temp_NOTIFYAREA = "3G8";
        end
     else
     if $204.#0140 = "HJBR" then
        begin
          $204.#temp_TRADINGPARTNER = "CHROSREF";
          $204.#temp_NOTIFYAREA     = "KEM"; 
        end
   end
else
if #0127 = "TMC SWS PPD" |   //*********************** Southern Wine
   #0127 = "TMC SWS"     | 
   #0127 = "TMC SWS DI"  then
   begin
     if $204.#0140 = "HJBB" then
        begin
          $204.#temp_NOTIFYAREA = "VJK";
        end
     else
        begin
          $204.#temp_NOTIFYAREA = "SJY";
        end
   end
else
if #0127 = "CONA STO" then //*********************** Cona
   begin
     if $204.#0140 = "HJBA" then
        begin
          $204.#temp_NOTIFYAREA = "VCF";
        end
     else
     if $204.#0140 = "HJBT" then
        begin 
          $204.#temp_NOTIFYAREA = "TBV";
        end
   end
else
if #0127 = "BOISE WHITE PAPER" then  //*********************** Boise White Paper
   begin
     if $204.#0140 = "HJBI" |
        $204.#0140 = "HJBT" then
        begin 
          $204.#temp_NOTIFYAREA = "JH2"; 
        end
   end
else
if #0127 = "BERRY PLASTICS" then  //*********************** Berry Plastics 
   begin
     if $204.#0140 = "HJBT" then
        begin 
          $204.#temp_TRADINGPARTNER = "CHRBERRYPL"; 
          $204.#temp_NOTIFYAREA     = "CZ2";
        end 
     else 
     if $204.#0140 = "HJBI" then
        begin 
          $204.#temp_TRADINGPARTNER = "CHRBRRYPLI";
          $204.#temp_NOTIFYAREA     = "LBR";
        end 
     else   
     if $204.#0140 = "HJBC" then
        begin
          $204.#temp_TRADINGPARTNER = "CHRBRRYJBC"; 
          $204.#temp_NOTIFYAREA     = "LBR";
        end 
   end
else
if #0127 = "TMC WABASH"    |  //*********************** WABASH
   #0127 = "SA-TMC WABASH" then
   begin
     if $204.#0140 = "HCDD" then
        begin
          $204.#temp_NOTIFYAREA = "JDI";
          $204.#temp_TRADINGPARTNER = "CHRWABABH";                 //// WABASH BACK HAUL
        end
   end
else
if #0127 = "BWAY TMC" &amp;   //*********************** BWAY
   $204.#0140 = "HJBI" then 
   begin 
     $204.#temp_NOTIFYAREA = "3C1"; 
   end
 else   
     if #0127 = "BWAY TMC" &amp; 
        $204.#0140 = "HJBM" then 
        begin 
          $204.#temp_TRADINGPARTNER = "CHRMSRBM"; 
          $204.#temp_NOTIFYAREA     = "ABW";
       end 
   end 
end   

if var_T_NBR = "T6013683"  then   //*********************** DOT Foods
  begin 
    $204.#temp_TRADINGPARTNER = "CHRDOTFOOD"; 
    $204.#temp_NOTIFYAREA = "RD6";
  end


/////////////////////////////////////////////////////MARKETPLACE///////////////////////////////////////////

if #0127 = "TMC - DOT FOODS" &amp; $204.#0140 = "HJBM" then  //*********************** DOT Foods 
  begin
    $204.#temp_TRADINGPARTNER = "CHRDOTM"; 
    $204.#temp_NOTIFYAREA = "#KP"; 
  end

if #0127 = "OCEAN SPRAY" &amp; $204.#0140 = "HJBM" then      //*********************** Ocean Spray
  begin
    $204.#temp_TRADINGPARTNER = "CHROCEANM"; 
    $204.#temp_NOTIFYAREA = "BSN";
  end


//////////////////////////////////////////////////////  L11 Qualifiers ////////////////////////////////////

if var_T_NBR = "T5296546" |
   var_T_NBR = "T4351816" |
   var_T_NBR = "T5331306" |
   var_T_NBR = "T4868430"  then
  begin
    if #0128 = "SI" then
      begin
        #temp_L11_HEADER_REFERENCE_QUALIFIER = "BM";
      end
  end
else
  if #0128 = "SI" then
    begin
      #temp_L11_HEADER_REFERENCE_QUALIFIER = "OQ";
    end
 
if #0128 = "CR" then
  begin
    #temp_L11_HEADER_REFERENCE_QUALIFIER = "CN";
  end
else
  if #0128 = "OW" then
    begin
      #temp_L11_HEADER_REFERENCE_QUALIFIER = "P8";
    end
  else
    if #0128 = "TH" then
      begin
        #temp_L11_HEADER_REFERENCE_QUALIFIER = "AE";
      end
    else
      if #0128 = "VD" then
        begin
          #temp_L11_HEADER_REFERENCE_QUALIFIER = "DJ";
        end
      else
        if #0128 = "MB" then
          begin
            #temp_L11_HEADER_REFERENCE_QUALIFIER = "BM";
          end

///////////////////////////////////////////////////////////////////////  COMMENTS MADE UP /////////////////////////////////////

if #0127 = "JCI-PS COMMON CARRIER FLEET TRL" |
   #0127 = "JCI-PS HAZMAT"                   |
   #0127 = "JCI-PS GMSPO"                    |
   #0127 = "JCI-PS TL NEW AND CORE"          |
   #0127 = "JCI-PS HAZWASTE"                 |
   #0127 = "JOHNSON CONTROLS"                |
   #0127 = "JOHNSON CONTROLS INC"            |
   #0127 = "SILGAN TMC"                      then
  begin
    $204.#temp_COMMENTSMADEUP = #0127;
  end
</ExplicitRule>

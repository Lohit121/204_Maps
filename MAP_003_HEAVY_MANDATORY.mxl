<ExplicitRule>#temp_L11_STOP_NUMBER = var_STOP_NUMBER;

#temp_L11_DETAIL_REFERENCE_QUALIFIER:2 = #0128:3;

if #0128:3 = "DO" then
   begin
     #temp_L11_DETAIL_REFERENCE_QUALIFIER:2 = "CO";
   end
else
   if #0128:3 = "PU" then
      begin
        #temp_L11_DETAIL_REFERENCE_QUALIFIER:2 = "AO";
      end

if (var_T_NBR = "T5296546" &amp; var_COMPANY = "CH ROBINSON") then
   begin
     if #0128:3 = "PU" then
        begin
          #temp_L11_DETAIL_REFERENCE_QUALIFIER:2 = "BM";
        end
     if #0128:3 = "BM" then
        begin
          #temp_L11_DETAIL_REFERENCE_QUALIFIER:2 = "PO";
        end
   end
else
   if (var_T_NBR = "T3130774" &amp; var_COMPANY = "CONA STO") then
      begin
        if #0128:3 = "DO" then
           begin
             #temp_L11_DETAIL_REFERENCE_QUALIFIER:2 = "PO";
           end
      end
   if (var_COMPANY = "TMC MAUSER" &amp; #0128:3 = "PU") |
      (var_COMPANY = "TMC MAUSER" &amp; #0128:3 = "DO") then
      begin
            #temp_L11_DETAIL_REFERENCE_QUALIFIER:2 = "BM";
           end

   if (var_COMPANY = "BBC TMC" &amp; #0128:3 = "PU") |
      (var_COMPANY = "BBC TMC" &amp; #0128:3 = "DO") then
      begin
            #temp_L11_DETAIL_REFERENCE_QUALIFIER:2 = "AO";
           end

   if var_COMPANY = "SILGAN TMC" &amp; len(#0127:4) = 8 then
        begin
          if left(#0127:4,2) = "20" then
              begin
                #temp_L11_DETAIL_REFERENCE_QUALIFIER:2 = "ZZ";
              end
        end

if $204.#temp_TRADINGPARTNER = "CHRCORNER" &amp;
   $0200_N7.#0207 = "" &amp;
   mid(#0127:4, 0,4) = "JBHU" then
   begin
     $0200_N7.#0207 = mid(#0127:4,4,6);
     $0200_N7.#0040 = "TF";
   end</ExplicitRule>

<ExplicitRule>string[90] temp_BILL_TO;

if #0098 = "VI" then
   begin
     #0098 = "OB";
   end

save_N101 = #0098;

if save_N101 = "BT" then
   begin
     $204.#temp_STOP_NUMBER:2 = 0;
     temp_BILL_TO = "BILL TO IS " + #0093:2 + " " + #0067;
     $204.#temp_REMARKS1:3    = mid(temp_BILL_TO,0,30);
     $204.#temp_REMARKS1:4    = mid(temp_BILL_TO,31,30);
     $204.#temp_REMARKS1:5    = mid(temp_BILL_TO,61,19);
   end
else
   begin
     cN1 = cN1 + 1;
     $temp_N1_LOOP[cN1].#temp_STOP_NUMBER  = 00;
     $temp_N1_LOOP[cN1].#temp_N101_ELEMENT = #0098;
     $temp_N1_LOOP[cN1].#temp_N102_ELEMENT = #0093:2;
     $temp_N1_LOOP[cN1].#temp_N103_ELEMENT = #0066;
     $temp_N1_LOOP[cN1].#temp_N104_ELEMENT = #0067;
   end

</ExplicitRule>

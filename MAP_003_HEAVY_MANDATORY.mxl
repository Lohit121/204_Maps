<StoreLimit>
<MaxLen>2</MaxLen>
<MinLen>2</MinLen>
<Signed>no</Signed>
<DataType>string</DataType>
<ImpliedDecimalPos>0</ImpliedDecimalPos>
<ImplicitDecimal>no</ImplicitDecimal>
<AllowSignedDecimal>0</AllowSignedDecimal>
<Format>X</Format>
<BinaryOutput>0</BinaryOutput>
<BinaryWidth>0</BinaryWidth>
</StoreLimit>
<ExplicitRule>var_STOPTYPE = #0163;

$temp_S5_Group[var_STOP_NUMBER].#temp_STOPTYPE = #0163;


if $204.#temp_TRADINGPARTNER = "CHRPHARM"  |
   $204.#temp_TRADINGPARTNER = "CHRPHARMI"  |
   $204.#temp_TRADINGPARTNER = "CHRPHAREF" then 
   begin 
     $temp_S5_Group[var_STOP_NUMBER].#temp_RFSTOPNUMBERD4 = #0165;
    if save_L11_SI &gt; "" then
      begin
         $temp_S5_Group[var_STOP_NUMBER].#temp_REFNUMBERD4 = save_L11_SI;
         $temp_S5_Group[var_STOP_NUMBER].#temp_REFQUALIFIERD4 = "AO";
      end
    end


if $204.#temp_TRADINGPARTNER = "CHROBIN" then
   begin
     if var_STOP_NUMBER = 1 then
        begin
          $temp_S5_Group[var_STOP_NUMBER].#temp_REMARKSEQNUMBERD = 1;
          $temp_S5_Group[var_STOP_NUMBER].#temp_REMARKS1D:2      = "CH ROBINSON 24HR NUMBER";
          $temp_S5_Group[var_STOP_NUMBER].#temp_REMARKS2D:2      = "If you require assistance";
          $temp_S5_Group[var_STOP_NUMBER].#temp_REMARKS3D:2      = "during your check-in process,";
        end
   end

if $204.#temp_TRADINGPARTNER = "CHROBIN" then
   begin
     if var_STOP_NUMBER = 1 then
        begin
          $temp_S5_Group[var_STOP_NUMBER].#temp_REMARKSEQNUMBERD:2 = 1;
          $temp_S5_Group[var_STOP_NUMBER].#temp_REMARKS1D:3        = "please use one of our mobile";
          $temp_S5_Group[var_STOP_NUMBER].#temp_REMARKS2D:3        = "apps, or call (800) 233-5623";
          $temp_S5_Group[var_STOP_NUMBER].#temp_REMARKS3D:3        = "WITH SHIPID";
        end
   end
 
</ExplicitRule>

     #0352:2 = #0352:2 + ",";
   end


#temp_REMARKS1 = mid(#0352:2,0,30);
#temp_REMARKS2 = mid(#0352:2,30,30);
#temp_REMARKS3 = mid(#0352:2,60,20);

//*************Make up SCAC based on comments for Boston Beer*******



if $204.#temp_TRADINGPARTNER = "CHRBBCTMCB"  &amp;
   $204.#temp_SCAC           = "HJBB"        &amp;
   left(#temp_REMARKS1,25)   = "Temp CTRL Min 36 / Max 40" then
      begin
        $204.#temp_SCAC           = "HJBR";
        $204.#temp_TRADINGPARTNER = "CHRBBCTMCT";
        $204.#temp_NOTIFYAREA = "KBR";  
      end

if $204.#temp_TRADINGPARTNER = "CHRBBCTMC"  &amp;
   $204.#temp_SCAC           = "HJBI"        &amp;
   left(#temp_REMARKS1,25)   = "Temp CTRL Min 36 / Max 40" then
      begin
        $204.#temp_SCAC           = "HJIR";
        $204.#temp_TRADINGPARTNER = "CHRBBCTMCT";
        $204.#temp_NOTIFYAREA = "KBR";  
      end






//******************************************************************


if $204.#temp_TRADINGPARTNER = "CHRPHARM"  &amp;
   left(#temp_REMARKS1,15)   = "Temp Control TL" then
      begin
        $204.#temp_TRADINGPARTNER = "CHRPHAREF";
      end

//******************************************************************

  if $204.#temp_TRADINGPARTNER = "CHRDOLE" &amp;                                                                                                                                                            
     $204.#0140                = "HJBI"    &amp;                                                                                                                                                            
     #0352:2                   = "Temp CTRL Min -10 / Max -10"      then                                                                                                                                                         
     begin                                                                                                                                                                                              
        $204.#temp_TRADINGPARTNER = "CHRDOLEIMR";                                                                                                                                                       
        $204.#temp_NOTIFYAREA     = "SPM";                                                                                                                                                              
     end   </ExplicitRule>

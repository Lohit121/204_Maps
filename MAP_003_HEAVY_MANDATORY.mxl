<ExplicitRule>$204.#temp_SCAC = #0140;

var_SCAC = #0140;

if #0140 = "HJBT" | 
   #0140 = "HJBA" |
   #0140 = "JBHA" |
   #0140 = "HJBB" |
   #0140 = "HJBR" then
  begin
    $204.#temp_TRANSPORTMETHCD = "T";
  end
else
   if #0140 = "HJBI" |
      #0140 = "HJIR" then
      begin
    $204.#temp_TRANSPORTMETHCD = "X";
  end

if len(#0140) &gt; 0 then
  begin
    $204.#temp_REPORTPRINTER = "R129";
  end</ExplicitRule>

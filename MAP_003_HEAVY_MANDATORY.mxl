<ExplicitRule>#temp_N1_STOP_NUMBER = var_STOP_NUMBER;

if var_COMPANY = "TETRAPAK NA" then
   begin
     if var_STOP_NUMBER = 1 then
        begin
          if #0026:2 = "MX" then
             begin
               $204.#temp_NOTIFYAREA = "MX0";
             end
        end
   end
else
   if var_COMPANY = "OCEAN SPRAY" then
      begin
        if (var_STOP_NUMBER != 1 &amp; #0026:2 = "MX" &amp; $204.#0140 = "HJBI")  then
           begin
             $204.#temp_NOTIFYAREA = "Y16";
           end
      end
   else
      if var_COMPANY = "KPLP - KRUGER PRODUCTS (USD)" then
         begin
           if (var_STOP_NUMBER != 1 &amp; #0026:2 = "MX")  then
              begin
                $204.#temp_NOTIFYAREA = "Y15";
              end
         end
      else
         if var_COMPANY = "TMC SWS PPD"    | 
            var_COMPANY = "TMC SWS"        | 
            var_COMPANY = "TMC SWS DI"     | 
            var_COMPANY = "TMC SWS PPD DI" then
            begin
              if $204.#0140 = "HJBT" then
                 begin
                   if (var_STOP_NUMBER = 1 &amp; #0156:3 = "KY")  then
                      begin
                        $204.#temp_NOTIFYAREA = "CC*";
                      end
                   else
                      if (var_STOP_NUMBER = 1 &amp; #0019:3 = "LAREDO")  then
                         begin
                           $204.#temp_NOTIFYAREA = "RF4";
                         end
                   else
                      if (var_STOP_NUMBER = 1 &amp; #0156:3 = "CA")  then
                         begin
                           $204.#temp_NOTIFYAREA = "MN&amp;";
                         end
                    else 
                      if (var_STOP_NUMBER = 1 &amp; #0156:3 = "MX")  then
                         begin
                           $204.#temp_NOTIFYAREA = "RF4";
                         end
                 end
              end
 

if var_COMPANY = "SA-FARMERBROTHERS" then
begin
 if var_STOP_NUMBER = 1 &amp; (#0019:3 = "Northlake" | #0019:3 = "NORTHLAKE") &amp; #0156:3 = "TX" then
 $204.#temp_NOTIFYAREA = "CHU";
 if var_STOP_NUMBER = 2 &amp; (#0019:3 = "Northlake" | #0019:3 = "NORTHLAKE") &amp; #0156:3 = "TX" then
 $204.#temp_NOTIFYAREA = "CHU";
 
 if var_STOP_NUMBER = 1 &amp; (#0019:3 = "Northlake" | #0019:3 = "NORTHLAKE") &amp; #0156:3 = "IL" then
 $204.#temp_NOTIFYAREA = "OGA";
 if var_STOP_NUMBER = 2 &amp; (#0019:3 = "Northlake" | #0019:3 = "NORTHLAKE") &amp; #0156:3 = "IL" then
 $204.#temp_NOTIFYAREA = "OGA";
 
 if var_STOP_NUMBER = 1 &amp; (#0019:3 = "Moonachie" | #0019:3 = "MOONACHIE") &amp; #0156:3 = "NJ" then
 $204.#temp_NOTIFYAREA = "3C9";
 if var_STOP_NUMBER = 2 &amp; (#0019:3 = "Moonachie" | #0019:3 = "MOONACHIE") &amp; #0156:3 = "NJ" then
 $204.#temp_NOTIFYAREA = "3C9"; 
end

if var_COMPANY = "SA-FARMERBROTHERS" &amp;
   $204.#0140  = "HBJI"              then
      begin
        $204.#temp_NOTIFYAREA = "7S7";
      end
     else
     
if var_COMPANY = "SA-FARMERBROTHERS" &amp;
   $204.#0140  = "HJBR"              then
      begin
        $204.#temp_NOTIFYAREA = "JBS";
      end
     else

if var_COMPANY = "TMC - DOT FOODS" &amp;
   $204.#0140  = "HJBT"              then
      begin
        $204.#temp_NOTIFYAREA = "!TR";
      
 end
////////////////////////////////////////    CH ROBINSON BROKERED LOAD  ----   L11*TH*CHROBINSON   ----- notify by COUNTRY   //////////////////

if var_T_NBR = "T5296546" then
   begin
     if var_STOP_NUMBER != 1 then
        begin
          if #0026:2 = "MX" then
             begin
               $204.#temp_NOTIFYAREA = "Y13";
             end
        end 
     else
        begin     
          $204.#temp_NOTIFYAREA = "JGA";
        end
   end
</ExplicitRule>

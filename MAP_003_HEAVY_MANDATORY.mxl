<Field>
<ID>1133</ID>
<Name>0040</Name>
<Description>EQUIPMENT DESCRIPTION CODE.............COMMENTS MADE UP &amp; Notify</Description>
<Active>1</Active>
<ChildCount>0</ChildCount>
<Note></Note>
<Mandatory>no</Mandatory>
<NotUsed>no</NotUsed>
<FieldNumber>0</FieldNumber>
<StoreGroup>65535</StoreGroup>
<StoreField>65535</StoreField>
<BusinessName></BusinessName>
<StoreLimit>
<MaxLen>2</MaxLen>
<MinLen>2</MinLen>
<Signed>no</Signed>
<DataType>string</DataType>
<ImpliedDecimalPos>0</ImpliedDecimalPos>
<ImplicitDecimal>no</ImplicitDecimal>
<AllowSignedDecimal>0</AllowSignedDecimal>
<Format>X</Format>
<BinaryOutput>0</BinaryOutput>
<BinaryWidth>0</BinaryWidth>
</StoreLimit>
<ExplicitRule>object trlr;


if #0040 = "TV" then 
  begin
    $204.#temp_COMMENTSMADEUP = "TRUCK LOAD";
  end
else
   if #0040 = "RT" then 
     begin
       $204.#temp_COMMENTSMADEUP = "REEFER";
     end
   else
      if #0040 = "FT"|
         #0040 = "FR" then 
         begin
           $204.#temp_COMMENTSMADEUP = "FLATBED";
         end
      else
         if #0040 = "DD" then 
            begin
              $204.#temp_COMMENTSMADEUP = "DROP DECK";
            end
         else
            if #0040 = "CN" then 
               begin
                 $204.#temp_COMMENTSMADEUP = "CONTAINER";
               end

//if var_COMPANY = "TMC SWS PPD" | 
//  (var_COMPANY = "TMC SWS"     &amp; 
//   #0040 = "RT")               then
//   begin
//     $204.#temp_NOTIFYAREA = "VJU";
//   end

//*************Make up SCAC based on trailer type Boston Beer*******

if $204.#temp_TRADINGPARTNER = "CHRBBCTMC" &amp;
   $204.#temp_SCAC           = "HJBI"      &amp;
   #0040                     = "RT"        then
      begin
        $204.#temp_SCAC = "HJIR";
      end

//******************************************************************
//***********Reefer Notify area for Starbucks***********************
if $204.#temp_TRADINGPARTNER = "CHRSTARBB" &amp; #0040 = "RT" then
   begin
      $204.#temp_TRADINGPARTNER = "CHRSBXREF";
      $204.#temp_NOTIFYAREA     = "CAH";
   end

//*****************************************************************
//***********Reefer TP/Notify for DOLE FOOD************************
if $204.#temp_TRADINGPARTNER = "CHRDOLE" &amp;
   $204.#0140                = "HJBI"    &amp;
   #0040                     = "RT"      then
   begin
      $204.#temp_TRADINGPARTNER = "CHRDOLEIMR";
      $204.#temp_NOTIFYAREA     = "L~E";
   end

///////////////////////////////////////////////////////////////////
//       Split out Reefer for CHRBBHJBM                          //
//////////////////////////////////////////////////////////////////

if $204.#temp_TRADINGPARTNER = "CHRBBHJBM" &amp;
   #0040                     = "RT"        then
   begin
     $204.#temp_TRADINGPARTNER = "CHRBBHJBMR";
   end

///////////////////////////////////////////////////////////////////
//       Split out Reefer for CHRHERB                           //
//////////////////////////////////////////////////////////////////

if $204.#temp_TRADINGPARTNER = "CHRHERB" &amp;
   #0040                     = "RT"        then
   begin
     $204.#temp_TRADINGPARTNER = "CHRHERBREF";
   end

//////////////////////////////////////////////////////////////////
//       Split out Flatbed for CHRINTELL                        //
//////////////////////////////////////////////////////////////////

if $204.#temp_TRADINGPARTNER = "CHRINTELL" &amp;
   #0040                     = "FT"        then
   begin
     $204.#temp_TRADINGPARTNER = "CHRINTELFB";
   end

//////////////////////////////////////////////////////////////////
//       Split out Flatbed for CHRXYLEM                         //
//////////////////////////////////////////////////////////////////

if $204.#temp_TRADINGPARTNER = "CHRXYLEM" &amp;
   #0040                     = "FT"        then
   begin
     $204.#temp_TRADINGPARTNER = "CHRXYEMFLB";
   end

//////////////////////////////////////////////////////////////////
//       Split out Reefer for CHRSUBWAY                         //
//////////////////////////////////////////////////////////////////

if $204.#temp_TRADINGPARTNER = "CHRSUBWAY" &amp;
   #0040                     = "RT"        then
   begin
     $204.#temp_TRADINGPARTNER = "CHRSUBREF";
   end

//////////////////////////////////////////////////////////////////
//       Split out Reefer for CHRBBCTMC                         //
//////////////////////////////////////////////////////////////////

if $204.#temp_TRADINGPARTNER = "CHRBBCTMC" &amp;
   #0040                     = "CN"        then
   begin
     $204.#temp_TRADINGPARTNER = "CHRBBCTIM";
   end

///////////////////////////////////////////////////////////////////
//       Split out Reefer for CHRBBCTMIM                         //
///////////////////////////////////////////////////////////////////

if $204.#temp_TRADINGPARTNER = "CHRBBCTMCT" &amp;
   #0040                     = "CN"        then
   begin
     $204.#temp_TRADINGPARTNER = "CHRBBCTMIM";
   end

//*****************************************************************

if #0207 &gt; "" then
 begin    
    trlr = new("java.lang.String");
    trlr = #0207;
   #0207 = trlr.replaceAll("[a-z,A-Z,/,\-,.,?,:,_,*,',`,#, ,]","");
 end

if $204.#temp_TRADINGPARTNER != "CHRBBHJBM"  &amp;
   $204.#temp_TRADINGPARTNER != "CHRBBHJBMR" &amp;
   
   (#0207 = "" |
   #0207 = "53" |
   #0207 = "48" |
   #0207 = "1" |
   #0207 = "0" | 
   #0207 = "00" | 
   #0207 = "000" |
   #0207 = "0000" |
   #0207 = "00000" | 
   #0207 = "000000" | 
   #0207 = "0000000" | 
   #0207 = "00000000" | 
   #0207 = "000000000" |
   #0207 = "0000000000") then
 begin
   empty (#0207);
   empty (#0567);
   empty (#0024);
   empty (#0040);
 end
 else

if #0207 = "" |
   #0207 = "53" |
   #0207 = "48" |
   #0207 = "1" |
   #0207 = "0" | 
   #0207 = "00" | 
   #0207 = "000" |
   #0207 = "0000" |
   #0207 = "00000" | 
   #0207 = "000000" | 
   #0207 = "0000000" | 
   #0207 = "00000000" | 
   #0207 = "000000000" |
   #0207 = "0000000000" then
begin
   empty (#0207);
end

</ExplicitRule>

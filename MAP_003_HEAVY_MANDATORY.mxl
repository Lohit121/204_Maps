<ExplicitRule>//$temp_S5_Group[var_STOP_NUMBER].#temp_STOPWEIGHT = #0081:8;

$temp_S5_Group[var_STOP_NUMBER].#temp_STOPWEIGHT = #0081:8 + $temp_S5_Group[var_STOP_NUMBER].#temp_STOPWEIGHT;


//Per Larry Coger, Boston Beer scales each pallet as they load drivers and works to max the weight out right at 44,500 lbs 
//need to map the weight of 44,500 lbs on all UCR's both Dry and Reefer for Boston Beer to avoid having to manually adjust weight &amp; allow loads to autoaccept 12132021//jisalb2

if $204.#temp_TRADINGPARTNER = "CHRBBHJBM" |
   $204.#temp_TRADINGPARTNER = "CHRBBHJBMR" then
   begin
     $temp_S5_Group[var_STOP_NUMBER].#temp_STOPWEIGHT = 44500;
   end

$temp_OID_GROUP[var_STOP_NUMBER][cPO].#temp_POWEIGHT = #0081:8;

//****************************************************************************************
//** Added logic to remove the Weight for all stops and order level
//** CHRLIPP partner - SCTASK0023089
//****************************************************************************************

if $204.#temp_TRADINGPARTNER = "CHRLIPP"  then
   begin
     $temp_S5_Group[var_STOP_NUMBER].#temp_STOPWEIGHT = 0;
     $temp_OID_GROUP[var_STOP_NUMBER][cPO].#temp_POWEIGHT = 0;
   end


</ExplicitRule>

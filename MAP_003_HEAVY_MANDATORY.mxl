<ID>1067</ID>
<Name>0163</Name>
<Description>STOP REASON CODE</Description>
<Active>1</Active>
<ChildCount>0</ChildCount>
<Note></Note>
<Mandatory>yes</Mandatory>
<NotUsed>no</NotUsed>
<FieldNumber>0</FieldNumber>

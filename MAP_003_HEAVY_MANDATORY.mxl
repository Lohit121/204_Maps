<ExplicitRule>$204.#temp_FINALSTOP   = var_STOP_NUMBER;

if var_COMPANY = "DOLE FOOD COMPANY" |
   var_COMPANY = "TMC SWS PPD"       | 
   var_COMPANY = "TMC SWS"           | 
   var_COMPANY = "TMC SWS DI"        |
   var_COMPANY = "TMC - DOT FOODS"   |
   var_COMPANY = "TMC STARBUCKS"     |
   var_COMPANY = "TETRAPAK NA"       |
//   var_COMPANY = "BWAY TMC"          |
   var_COMPANY = "POOLCORP"          |
   var_COMPANY = "BERRY PLASTICS"    |
   var_COMPANY = "OCEAN SPRAY"       then
  begin
    $temp_S5_Group[1].#temp_STOPWEIGHT = #0081:12;
  end

if $L11[1].#0127 = "T5290261" then
  begin
    $temp_S5_Group[1].#temp_STOPWEIGHT = #0081:12;
  end

if $L11[1].#0127 ="T6034313" then
  begin
    $temp_S5_Group[1].#temp_STOPWEIGHT = #0081:12;
  End

//****************************************************************************************
//** Added logic to remove the Weight for all stops and order level
//** CHRLIPP partner - SCTASK0023089
//****************************************************************************************

if $204.#temp_TRADINGPARTNER = "CHRLIPP"  then
   begin
     #0081:12 = 0;
   end

</ExplicitRule>
